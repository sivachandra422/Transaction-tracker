# ── Backend (Express / Vercel) ────────────────────────────────────────────────
# Used server-side for AI parsing when user has no API key configured
GEMINI_API_KEY="your_gemini_api_key_here"

# ── Frontend (Vite build-time) ────────────────────────────────────────────────
# URL of the deployed backend (Vercel). REQUIRED for Android/Capacitor builds.
# Example: https://transaction-tracker.vercel.app
VITE_API_URL="https://your-vercel-deployment.vercel.app"

# Supabase — get from https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL="https://fexbynoduaderbrjmqtz.supabase.co"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key"

# (Legacy / AI Studio) The URL where this app is hosted
APP_URL="MY_APP_URL"
